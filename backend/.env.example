# ═══════════════════════════════════════════════════════════
#   ORIEN | COGNITIVE CORE — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your keys.

# ── Primary Cognitive Bridge ──────────────────────────────
# Primary Engine Key (Required)
PRIMARY_CORE_KEY=your_key_here

# ── Secondary Bridges ──────────────────────────────────
# Optional fallback keys
SECONDARY_CORE_KEY=your_key_here
TERTIARY_CORE_KEY=your_key_here

# ── System Settings ─────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Local Processing (Optional) ─────────────────────────
# LOCAL_CORE_URL=http://localhost:11434
# LOCAL_CORE_MODEL=identified_model
